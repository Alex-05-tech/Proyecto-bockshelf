{
  "info": {
    "name": "Bookshelf — Tests Automáticos",
    "description": "Colección con scripts de test automáticos.\n\n⚠️ ANTES DE EMPEZAR:\n1. Levanta los contenedores: docker compose up --build\n2. En Postman Settings activa 'Automatically follow redirects' y 'Save cookies'\n3. Ejecuta las peticiones EN ORDEN",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" }
  ],
  "item": [

    {
      "name": "🔐 AUTH",
      "item": [

        {
          "name": "1. Registro de nuevo usuario",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('✅ Status 200 o 302 (registro OK)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
            "});",
            "pm.test('✅ No aparece error de usuario duplicado', function () {",
            "    pm.expect(pm.response.text()).to.not.include('ya existe');",
            "});"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] },
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "username", "value": "testuser_postman" },
              { "key": "email",    "value": "testpostman@prueba.com" },
              { "key": "password", "value": "1234abcd" }
            ]}
          }
        },

