          "name": "1. Registro de nuevo usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status es 200 o 302 (registro OK)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});",
                  "",
                  "pm.test('✅ El servidor responde', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test('✅ No aparece error de usuario duplicado', function () {",
                  "    const html = pm.response.text();",
                  "    pm.expect(html).to.not.include('ya existe');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] },
